# Public (servidor + bundle cliente — sólo valores no secretos)
NEXT_PUBLIC_INSTAGRAM_URL=

# Supabase (proyecto byrousos-core)
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui  ← SECRETO, nunca al cliente
SUPABASE_SERVICE_ROLE_KEY=

# PostgreSQL directo — os.* únicamente (bypasea PostgREST)
# Supabase → Project Settings → Database → Connection string → URI (Transaction pooler, puerto 6543)
DATABASE_URL=

# IA (solo servidor — leídas también por SDKs mediante process.env estándar)
# AI_PROVIDER=openai   # opcional; por defecto: openai si OPENAI existe, si no anthropic, si ninguno mock
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
